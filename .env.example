# =============================================================================
# s7labs.ai — environment variables
# =============================================================================
# Copy this file to .env.local for development and fill in the real values.
# .env.local is gitignored. Production values are set in Vercel.
#
# Conventions:
#   NEXT_PUBLIC_* is exposed to the browser. Never put secrets here.
#   Everything else is server-only and must NEVER be sent to the client.
# =============================================================================


# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
# Public base URL of the deployed app. Used by /unsubscribe link builder and the
# n8n result-email webhook payload. Falls back to https://s7labs.ai if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legacy alias still consumed by src/lib/env.ts. Keep in sync with SITE_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER commit. NEVER expose to the client. Used by the Supabase
# server client at src/lib/supabase/server.ts to bypass RLS for trusted writes.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
# Anthropic — primary model provider for the LLM-backed mini-apps
# (pricing-diagnostic, website-roast, agentic-readiness, share-of-voice, etc.).
ANTHROPIC_API_KEY=

# Perplexity — used by ai-visibility-score and avs-perplexity helper.
PERPLEXITY_API_KEY=


# -----------------------------------------------------------------------------
# Data / scraping providers
# -----------------------------------------------------------------------------
# Firecrawl — page fetch and parse for pricing-diagnostic, website-roast, and
# the intent-signals collectors.
FIRECRAWL_API_KEY=

# DataForSEO — used by share-of-voice (sov-providers) and the
# ai-overview-tracker scan pipeline. Login + password pair, not an API key.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google PageSpeed Insights — used by website-roast for the performance section.
PAGESPEED_API_KEY=

# Apollo — used by find-people and bulk-email-finder once enabled.
APOLLO_API_KEY=


# -----------------------------------------------------------------------------
# Tech detection providers (tech-stack-finder)
# -----------------------------------------------------------------------------
# Which provider implementation to load. Default 'stub' returns mocked data.
TECH_DETECT_PROVIDER=stub
# Optional override that lets a deployment point at a custom provider module
# path (loaded dynamically). Leave blank to use the built-in providers.
TECH_STACK_PROVIDER_MODULE=


# -----------------------------------------------------------------------------
# n8n webhooks (all server-only, never NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
# Transactional result email. Fired by /api/leads/complete after each
# successful mini-app submission, and by /api/results/resend.
N8N_EMAIL_WEBHOOK_URL=https://system7ai.app.n8n.cloud/webhook/s7labs-mini-app-result

# Get Sales Insights form submissions (/revops/sales-insights).
N8N_SALES_INSIGHTS_WEBHOOK_URL=https://system7ai.app.n8n.cloud/webhook/s7labs/revops/sales-insights/submit

# Voice Agent provisioning submissions (/revops/voice-agent).
N8N_VOICE_AGENT_WEBHOOK_URL=https://system7ai.app.n8n.cloud/webhook/s7labs/revops/voice-agent/submit

# Generic mini-app lead capture forwarder used by capture-lead helper.
N8N_MINI_APPS_LEAD_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# ElevenLabs (voice agent + chatbot)
# -----------------------------------------------------------------------------
# Public agent ID for the embedded conversational AI chatbot widget.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
# Public kill-switch for the chatbot. Set to true once configured.
NEXT_PUBLIC_ELEVENLABS_CHATBOT_ENABLED=false
# Public-facing phone number visitors can dial directly (display + tel: link).
NEXT_PUBLIC_ELEVENLABS_PUBLIC_PHONE=

# Server-only API key. Used by /api/voice/outbound-call.
ELEVENLABS_API_KEY=
# Agent phone number ID (phnum_...) assigned to the agent. Server-only.
ELEVENLABS_AGENT_PHONE_NUMBER_ID=


# -----------------------------------------------------------------------------
# Public feature kill-switches
# -----------------------------------------------------------------------------
# AI Overview Tracker mini-app gate. Disable in environments without
# DataForSEO credentials wired up.
NEXT_PUBLIC_AI_OVERVIEW_TRACKER_ENABLED=false

# Find People mini-app gate. Keep false until Apollo integration is verified.
NEXT_PUBLIC_FIND_PEOPLE_ENABLED=false
